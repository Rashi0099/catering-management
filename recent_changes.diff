+        a.download = name + '.pdf';
+        document.body.appendChild(a);
+        a.click();
+        setTimeout(() => { window.URL.revokeObjectURL(blobUrl); a.remove(); }, 300);
+        btn.disabled  = false;
+        btn.innerHTML = oldHtml;
+      })
+      .catch(() => {
+        btn.disabled  = false;
+        btn.innerHTML = oldHtml;
