+      <script>
+      // Attendance AJAX for Staff Portal
+      function saveAttField(el) {
+          const staffId = el.dataset.staff;
+          const field = el.dataset.field;
+          let value = el.type === 'checkbox' ? (el.checked ? 'true' : 'false') : el.value;
+          
+          const card = el.closest('.prm-att-card');
+          if (card) {
+              card.style.opacity = '0.6';
+              card.style.transform = 'scale(0.99)';
+          }
+
+          const formData = new FormData();
+          formData.append('staff_id', staffId);
+          formData.append('field', field);
+          formData.append('value', value);
+          formData.append('csrfmiddlewaretoken', document.querySelector('input[name="csrfmiddlewaretoken"]').value);
+
+          fetch("{% url 'staff_ajax_update_attendance_field' booking.pk %}", {
+              method: 'POST',
+              body: new URLSearchParams(formData)
+          })
+          .then(r => r.json())
+          .then(data => {
+              if (card) {
+                  card.style.opacity = '1';
+                  card.style.transform = 'scale(1)';
+              }
+              if (data.status === 'success') {
+                  if (card) {
+                      card.style.borderColor = 'var(--green)';
+                      setTimeout(() => card.style.borderColor = 'rgba(255,255,255,0.05)', 1000);
+                  }
+                  if(typeof showNotifToast !== 'undefined') showNotifToast(`✅ ${field.replace('_',' ')} saved`, "success");
+              } else {
+                  if(typeof showNotifToast !== 'undefined') showNotifToast(data.message || "Save failed", "error");
+                  if (el.type === 'checkbox') el.checked = !el.checked;
+              }
+          })
+          .catch(err => {
+              if (card) {
+                  card.style.opacity = '1';
+                  card.style.transform = 'scale(1)';
+                  card.style.borderColor = 'var(--red)';
+              }
+              if(typeof showNotifToast !== 'undefined') showNotifToast("Connection Error", "error");
+          });
+      }
+
+      document.querySelectorAll('.att-ajax').forEach(el => {
+          const eventType = el.tagName === 'SELECT' ? 'change' : 'blur';
+          el.addEventListener(eventType, function(e) {
+              e.stopPropagation();
+              saveAttField(this);
+          });
+      });
+
+      document.querySelectorAll('.att-ajax-trigger').forEach(btn => {
+          btn.addEventListener('click', function(e) {
+              e.preventDefault();
+              e.stopPropagation();
+              const card = this.closest('.prm-att-card');
+              if (card) {
+                  card.querySelectorAll('.att-ajax').forEach(input => saveAttField(input));
+                  if(typeof showNotifToast !== 'undefined') showNotifToast("Saving staff data...", "info");
+              }
+          });
+      });
+      </script>
