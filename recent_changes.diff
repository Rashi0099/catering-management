+
+// AJAX Field Auto-save
+document.querySelectorAll('.ajax-update').forEach(el => {
+    let timeout = null;
+    el.addEventListener('input', () => {
+        clearTimeout(timeout);
+        timeout = setTimeout(() => {
+            const field = el.getAttribute('data-field');
+            const val = el.value;
+            
+            fetch("{% url 'admin_ajax_update_booking_field' booking.pk %}", {
+                method: 'POST',
+                headers: {
+                    'Content-Type': 'application/x-www-form-urlencoded',
+                    'X-CSRFToken': '{{ csrf_token }}'
+                },
+                body: `field=${field}&value=${encodeURIComponent(val)}`
+            })
+            .then(r => r.json())
+            .then(data => {
+                if(data.status === 'success') {
+                    el.style.borderColor = 'var(--green)';
+                    setTimeout(() => el.style.borderColor = '', 1000);
+                } else {
+                    if(typeof showNotifToast !== 'undefined') showNotifToast(data.message || "Update Failed", "error");
+                }
+            });
+        }, 800);
+    });
+    
+    // For selects, update immediately
+    if (el.tagName === 'SELECT') {
+        el.addEventListener('change', () => {
+            const field = el.getAttribute('data-field');
+            const val = el.value;
+            fetch("{% url 'admin_ajax_update_booking_field' booking.pk %}", {
+                method: 'POST',
+                headers: {
+                    'Content-Type': 'application/x-www-form-urlencoded',
+                    'X-CSRFToken': '{{ csrf_token }}'
+                },
+                body: `field=${field}&value=${encodeURIComponent(val)}`
+            })
+            .then(r => r.json())
+            .then(data => {
+                if(data.status === 'success') {
+                    if(typeof showNotifToast !== 'undefined') showNotifToast("✅ Updated Successfully", "success");
+                }
+            });
+        });
+    }
+});
+
+// Staff Assignment Auto-save
+document.querySelectorAll('.assigned-to-ajax').forEach(cb => {
+    cb.addEventListener('change', function() {
+        const staffId = this.value;
+        const subAction = this.checked ? 'add' : 'remove';
+        
+        fetch("{% url 'admin_ajax_update_booking_field' booking.pk %}", {
+            method: 'POST',
+            headers: {
+                'Content-Type': 'application/x-www-form-urlencoded',
+                'X-CSRFToken': '{{ csrf_token }}'
+            },
+            body: `field=assigned_to&value=${staffId}&sub_action=${subAction}`
+        })
+        .then(r => r.json())
+        .then(data => {
+            if(data.status === 'success') {
+                if(typeof showNotifToast !== 'undefined') showNotifToast(data.message || "Assignment Updated", "success");
+                
+                // Update Ribbon Counts
+                if (data.filled) {
+                    for (const [role, count] of Object.entries(data.filled)) {
+                        const el = document.getElementById(`q-val-${role.toLowerCase()}`);
+                        if (el) el.innerText = count;
+                    }
+                }
+                if (data.total_filled !== undefined) {
+                    const filledEl = document.getElementById('total-filled-num');
+                    if (filledEl) {
+                        filledEl.innerText = data.total_filled;
+                        const totalQuota = parseInt(document.getElementById('total-quota-num').innerText) || 0;
+                        const displayEl = document.getElementById('quota-total-display');
+                        if (displayEl) {
+                            displayEl.style.color = (data.total_filled >= totalQuota) ? 'var(--green)' : '#fff';
+                        }
+                    }
+                }
+            } else {
+                if(typeof showNotifToast !== 'undefined') showNotifToast(data.message || "Assignment Failed", "error");
+                // Revert checkbox state on failure
+                this.checked = !this.checked;
+            }
+        });
+    });
+});
 </script>
 
 {% endblock %}
