[
{
  "model": "core.termandcondition",
  "pk": 1,
  "fields": {
    "text": "ജോലി ചെയ്യുന്ന കമ്പനിയോട് വിശ്വസ്തതയും കൂറും പുലർത്തുന്നവർ ആയിരിക്കണം. വർക്ക് ബുക്ക് ചെയ്താൽ നിർബന്ധമായും സൈറ്റിൽ എത്തണം. \"ക്യാൻസലേഷൻ അനുവദിക്കുകയില്ല\".",
    "order": 0,
    "created_at": "2026-04-27T08:41:07.372"
  }
},
{
  "model": "core.termandcondition",
  "pk": 2,
  "fields": {
    "text": "കൃത്യമായ സമയത്ത് സൈറ്റിൽ എത്തുകയും ക്യാപ്റ്റൻ/സീനിയേഴ്സ് പറഞ്ഞതനുസരിച്ച് വർക്ക് ചെയ്യുകയും ചെയ്താൽ താങ്കളിലുള്ള വിശ്വാസം വർദ്ധിപ്പിക്കാൻ അത് കാരണമാകും.",
    "order": 0,
    "created_at": "2026-04-27T08:41:07.377"
  }
},
{
  "model": "core.termandcondition",
  "pk": 3,
  "fields": {
    "text": "അച്ചടക്കമുള്ള നല്ല സ്റ്റാഫുകളെ വാർത്തെടുക്കാൻ മൂല്യനിർണയം നടത്തും. വർക്കിന് പ്രവേശിച്ചാൽ പിന്നീടുള്ള സമയങ്ങളിൽ മൊബൈലുകൾക്ക് ഏർപ്പെടുത്തിയ നിയന്ത്രണത്തിന് താങ്കൾ പൂർണ്ണമായും സഹകരിക്കണം.",
    "order": 0,
    "created_at": "2026-04-27T08:41:07.382"
  }
},
{
  "model": "core.termandcondition",
  "pk": 4,
  "fields": {
    "text": "റിപ്പോർട്ടിംഗ് മുതൽ ഡിസ്പോസൽ വരെ താങ്കളുടെ ഉത്തരവാദിത്വം കമ്പനിക്ക് ആയിരിക്കും.",
    "order": 0,
    "created_at": "2026-04-27T08:41:07.385"
  }
},
{
  "model": "core.termandcondition",
  "pk": 5,
  "fields": {
    "text": "കമ്പനി ഏൽപ്പിച്ച ക്യാപ്റ്റൻ ആയിരിക്കും സൈറ്റിനെ പൂർണ ചുമതല. ക്യാപ്റ്റൻ തരുന്ന നിർദ്ദേശങ്ങൾ പാലിക്കാൻ താങ്കൾ ബാധ്യസ്ഥനാണ്.",
    "order": 0,
    "created_at": "2026-04-27T08:41:07.389"
  }
},
